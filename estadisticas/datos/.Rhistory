left_join(Meses, by="Mes") %>%
filter(Tipo != "Abuso sexual") %>%
mutate(Año = as.character(Año)) %>%
group_by(Mes, Año) %>%
summarise(Cantidad = sum(Cantidad)) %>%
arrange(Mes, Año)
View(Data1)
