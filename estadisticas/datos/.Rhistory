library(tidyr)
# Caratulas femicidios
Data11_2 <- Raw0 %>%
mutate(Año = as.character(Año)) %>%
group_by(Año, Vinculado) %>%
summarise(Cantidad = n(), .groups = "drop") %>%
pivot_wider(
names_from = Vinculado,
values_from = Cantidad,
values_fill = 0
) %>%
rename(
Directos = `FALSE`,
Vinculados = `TRUE`
) %>%
mutate(
Texto = paste0(
Directos,
if_else(Directos == 1,
" femicidio directo",
" femicidios directos"),
if_else(
Vinculados > 0,
paste0(
"\n",
Vinculados,
if_else(Vinculados == 1,
" femicidio vinculado",
" femicidios vinculados")
),
""
)
)
)
View(Data11_2)
