rename( Directos = `FALSE`, Vinculados = `TRUE`) %>%
mutate(Texto = paste0(Directos,
if_else(Directos == 1,
" femicidio directo",
" femicidios directos"),
if_else(
Vinculados > 0,
paste0(
"\n",
